doctype

include ../../node_modules/aglio-theme-olio/templates/mixins.jade

html
    head
        meta(charset="utf-8")
        meta(name="viewport", content="width=device-width, initial-scale=1")
        title= self.api.name || 'Nexio IMDb API Documentation'
        link(rel="preconnect", href="https://fonts.googleapis.com")
        link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin="")
        link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;700;800&family=Inter:wght@400;500;600;700&display=swap")
        link(rel="stylesheet", href="https://maxcdn.bootstrapcdn.com/font-awesome/4.3.0/css/font-awesome.min.css")
        style!= self.css
    body.preload.nexio-docs
        .docs-shell
            #nav-background
            .container-fluid.triple.docs-layout
                .row
                    block nav
                        +Nav()

                    .content
                        #right-panel-background

                        block content
                            +ContentTriple()

                        .middle
                            p.text-muted.docs-credit
                                | Generated by&nbsp;
                                a.aglio(href="https://github.com/danielgtaylor/aglio") aglio
                                | &nbsp;on #{self.date().format('DD MMM YYYY')}

        script: include ../../node_modules/aglio-theme-olio/templates/scripts.js

        if self.livePreview
            script(src="/socket.io/socket.io.js")
            script.
                var socket = io();
                socket.on('refresh', refresh);
                socket.on('reconnect', function () {
                    socket.emit('request-refresh');
                });
